# Required — from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Optional — SQLite database (default is fine for local use)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# Ollama (local AI for task breakdown)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_MODEL=phi3:mini

# Limit AI breakdown calls per user per day
MAX_BREAKDOWNS_PER_DAY=20
